# ============================================
# Mourya Scholarium — Environment Configuration
# ============================================
# Copy this file to .env and fill in your values.
# For local development, most defaults work out of the box.

# --- Application ---
APP_ENV=development                          # development | production
APP_SECRET_KEY=change-me-to-a-random-64-char-string
APP_DEBUG=true
CORS_ORIGINS=http://localhost:3000           # Comma-separated allowed origins
USE_SQLITE=true                              # Set to false when PostgreSQL is available

# --- PostgreSQL (used when USE_SQLITE=false) ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mourya_scholarium
POSTGRES_USER=mourya
POSTGRES_PASSWORD=change-me

# --- Redis (optional for MVP) ---
REDIS_URL=redis://localhost:6379/0

# --- Qdrant Vector DB (optional for MVP) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333

# --- LLM Provider (Anthropic) ---
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_MODEL_OPUS=claude-sonnet-4-20250514
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-20250514
ANTHROPIC_MODEL_HAIKU=claude-sonnet-4-20250514

# --- Scholarly APIs ---
SEMANTIC_SCHOLAR_API_KEY=
CROSSREF_MAILTO=your-email@institution.edu
CORE_API_KEY=
OPENALEX_MAILTO=your-email@institution.edu

# --- JWT Auth ---
JWT_SECRET_KEY=change-me-to-a-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

# --- Frontend ---
NEXT_PUBLIC_API_URL=http://localhost:8000     # Backend URL for frontend to call
